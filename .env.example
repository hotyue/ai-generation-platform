# =========================
# 🌐 平台基础配置 (Platform)
# =========================
# 你的前端公网域名 (触发 entrypoint 动态注入)
API_BASE_URL=https://ai.598000.xyz
# 允许跨域的来源列表 (供 Backend CORS 使用)
FRONTEND_ORIGINS=https://ai.598000.xyz

# =========================
# 💾 数据库核心设定 (MariaDB 11)
# =========================
DB_PASSWORD=change_this_to_a_strong_password
DB_NAME=ai_generation

# =========================
# 🔐 后端安全配置 (Backend Secrets)
# =========================
JWT_SECRET=generate_a_random_long_string_here_like_uuid
JWT_ALGORITHM=HS256

# =========================
# 🚀 外部算力节点配置 (ComfyUI)
# =========================
COMFY_API_BASE=http://100.114.23.111:9000