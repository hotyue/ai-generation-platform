# ---------------------------
# Cloudflare R2
# ---------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_PUBLIC_BASE=https://aiimgcdn.example.com

# ---------------------------
# Compute runtime
# ---------------------------
# 如果 ComfyUI 运行在宿主机 Windows 上，容器访问宿主机请用 host.docker.internal
# 若你未来算力机换 Linux，可改成宿主机 IP 或者把 ComfyUI 也容器化并进同网络
COMFY_API=http://host.docker.internal:8188

# 对外 image_url 语义冻结后的域名
# 临时访问域名/前缀：如果你用 tunnel 指到 nginx，那么这里写你的外网域名即可
# 若只在内网测试，可先写 http://<算力机IP>:8081/outputs
# PUBLIC_BASE_URL: http://host.docker.internal:8081/outputs
PUBLIC_BASE_URL=https://aiimg.example.com/outputs

# ---------------------------
# Host paths
# ---------------------------
HOST_OUTPUT_DIR=/path/to/comfyui/output
