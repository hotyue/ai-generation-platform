FROM python:3.10-slim

# --------------------------------------------------
# 1. Python 模块根路径裁决
# --------------------------------------------------
ENV PYTHONPATH=/app

# --------------------------------------------------
# 2. 工作目录
# --------------------------------------------------
WORKDIR /app

# --------------------------------------------------
# 3. 拷贝算力 API 源码
#    build context = ./compute_api
#    所以这里只能写 app
# --------------------------------------------------
COPY app /app/app

# --------------------------------------------------
# 4. 运行依赖（冻结最小集）
# --------------------------------------------------
RUN pip install --no-cache-dir \
    fastapi \
    uvicorn \
    requests \
    boto3

# --------------------------------------------------
# 5. 启动命令（与包结构强一致）
# --------------------------------------------------
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "9000"]
